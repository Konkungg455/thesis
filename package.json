{
  "name": "telebot_pharmacy",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/dev.ps1",
    "dev:nuxt": "nuxt dev",
    "dev:web": "powershell -Command \"$env:SKIP_AI='1'; npm run dev\"",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "demo": "powershell -ExecutionPolicy Bypass -File ./scripts/start-thesis-demo.ps1",
    "demo:check": "powershell -ExecutionPolicy Bypass -File ./scripts/check-thesis-demo.ps1",
    "ai:start": "powershell -ExecutionPolicy Bypass -File ./scripts/start-ai-local.ps1",
    "ai:check": "powershell -ExecutionPolicy Bypass -File ./scripts/check-ai-local.ps1",
    "ngrok:check": "powershell -ExecutionPolicy Bypass -File ./scripts/check-ngrok-n8n.ps1",
    "media:seed": "node scripts/seed-supabase-media.mjs",
    "media:migrate": "node scripts/migrate-media-to-supabase.mjs",
    "db:check": "node scripts/test-db.mjs"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@nuxt/image": "^2.0.0",
    "@supabase/supabase-js": "^2.108.2",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "html2pdf.js": "^0.14.0",
    "nodemailer": "^9.0.1",
    "nuxt": "^4.3.1",
    "peerjs": "^1.5.5",
    "postgres": "^3.4.9",
    "puppeteer": "^25.2.1",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  }
}
