# คัดเป็น .env — โปรเจกต์ใช้ Supabase + /api/bff (ไม่ใช้ XAMPP)
# รัน dev: npm run dev  →  http://localhost:3001

# ว่างได้ — ลิงก์ reset password ใช้ domain จาก request อัตโนมัติ
NUXT_PUBLIC_SITE_ORIGIN=
NUXT_PORT=3001

# --- Supabase (จำเป็น) ---
# Project Settings → API
NUXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=sb_publishable_xxx
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server only — อัปโหลดรูป / Storage
SUPABASE_STORAGE_BUCKET=media
NUXT_PUBLIC_USE_SUPABASE_BACKEND=true

# --- PostgreSQL (จำเป็น — login, เภสัช, แชท) ---
# Supabase → Database → Connection pooling → Transaction → port 6543
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres
# (รหัสผ่านที่มี @ → %40)
DATABASE_URL=

# --- AI Chat ---
# Local dev: n8n + Ollama (npm run ai:start) + Groq fallback ถ้ามี NUXT_AI_API_KEY
NUXT_AI_MODE=n8n
NUXT_N8N_INTERNAL_URL=http://127.0.0.1:5678
NUXT_PUBLIC_N8N_CHAT_WEBHOOK_ID=1f5ea30f-2ff0-4d32-b211-eccb342ee0df

# Vercel (แนะนำ): Groq โดยตรง — ไม่ต้องเปิด n8n บน PC
# NUXT_AI_MODE=cloud
NUXT_AI_API_KEY=gsk_xxx
NUXT_AI_PROVIDER=groq
NUXT_AI_MODEL=llama-3.3-70b-versatile

# Vercel ทางเลือก: n8n ผ่าน ngrok (NUXT_AI_MODE=n8n)
# NUXT_N8N_INTERNAL_URL=https://xxxx.ngrok-free.dev

# --- ngrok demo (optional) ---
# ngrok http 3001  →  /api/bff + /api/ai-chat + /n8n proxy อัตโนมัติ

# --- SMTP (OTP / ลืมรหัสผ่าน) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=your@gmail.com
# SMTP_FROM_NAME=Telebot Pharmacy

# อัปโหลดรูปครั้งแรก: npm run media:seed
