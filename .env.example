# คัดเป็น .env แล้วแก้ IP ให้ตรงเครื่องที่รัน XAMPP / n8n
# ตัวอย่าง LAN: เปิดเว็บที่ http://192.168.1.117:3001
#   - PHP อยู่ที่ http://192.168.1.117/4
#   - n8n อยู่ที่ http://192.168.1.117:5678

# ปล่อยว่าง = ใช้ IP ปัจจุบันอัตโนมัติ (แนะนำ)
NUXT_PUBLIC_API_BASE=
NUXT_PUBLIC_N8N_BASE=
NUXT_PUBLIC_N8N_CHAT_WEBHOOK_ID=1f5ea30f-2ff0-4d32-b211-eccb342ee0df
NUXT_PORT=3001

# Proxy ไป XAMPP ตอนใช้ ngrok (ค่าเริ่มต้น http://127.0.0.1 = Apache port 80)
# NUXT_PROXY_API_TARGET=http://127.0.0.1

# --- วันทดสอบ Thesis (แนะนำ) ---
#   .\scripts\start-thesis-demo.ps1
#   หรือ: ngrok http 3001
#   เปิด https://xxxx.ngrok-free.dev — API ผ่าน /4 อัตโนมัติ ไม่ต้องแก้ env

# --- LAN โดยตรง (WiFi เดียวกัน) ---
# NUXT_PUBLIC_API_BASE=http://192.168.1.117/4

# --- Supabase (Project Settings → API) ---
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_KEY=sb_publishable_xxx
# SUPABASE_ENABLED=true
# SUPABASE_SERVICE_ROLE_KEY=   # server-side only — อย่าใส่ใน frontend
#
# โหมด AI Chat ไม่ต้องเปิด XAMPP — รันแค่:
#   npm run dev         # เปิด Nuxt + Ollama + n8n อัตโนมัติ
#   npm run ai:check    # ทดสอบ webhook (ถ้าต้องการ)
#   npm run dev:nuxt    # Nuxt อย่างเดียว ไม่เปิด AI
# n8n (port 5678) + Ollama (11434) สำหรับตอบ AI
# ประวัติแชทบันทึกที่ Supabase ผ่าน /api/chat/*
#
# DATABASE_URL — ใช้ Pooler (ไม่ใช่ db.xxx.supabase.co) สำหรับ Vercel
# Supabase → Database → Connection pooling → Transaction → port 6543
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres
# (รหัสผ่านที่มี @ → %40)
# NUXT_PUBLIC_SUPABASE_URL= + NUXT_PUBLIC_SUPABASE_KEY=
# NUXT_AI_API_KEY=gsk_xxx  (Vercel AI — Groq ฟรี console.groq.com, ไม่ต้อง ngrok)
# NUXT_AI_PROVIDER=groq
# NUXT_AI_MODEL=llama-3.3-70b-versatile
# NUXT_N8N_INTERNAL_URL=  (local dev only — ไม่จำเป็นบน Vercel)
# (รหัสผ่านที่มี @ ให้เขียนเป็น %40)
# SUPABASE_STORAGE_BUCKET=media
# MEDIA_ROOT=C:/xampp/htdocs/4
#
# SMTP สำหรับ OTP / ลืมรหัสผ่าน (Gmail App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=your@gmail.com
# SMTP_FROM_NAME=TELEBOTPHARCY OTP
