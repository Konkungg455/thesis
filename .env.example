# คัดเป็น .env — โปรเจกต์ใช้ Supabase + /api/bff (ไม่ใช้ XAMPP)
# รัน dev: npm run dev  →  http://localhost:3001

# ว่างได้ — ลิงก์ reset password ใช้ domain จาก request อัตโนมัติ
NUXT_PUBLIC_SITE_ORIGIN=
NUXT_PORT=3001

# --- Supabase (จำเป็น) ---
# Project Settings → API
NUXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=sb_publishable_xxx
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server only — อัปโหลดรูป / Storage
SUPABASE_STORAGE_BUCKET=media
NUXT_PUBLIC_USE_SUPABASE_BACKEND=true

# --- PostgreSQL (จำเป็น — login, เภสัช, แชท) ---
# Supabase → Database → Connection pooling → Transaction → port 6543
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
# (รหัสผ่านที่มี @ → %40)
# Vercel: ห้ามใช้ direct db.xxx.supabase.co:5432 — ใช้ pooler 6543 เท่านั้น
# ถ้า region ไม่ใช่ aws-1-ap-southeast-1 ให้ตั้ง SUPABASE_POOLER_HOST=aws-0-xxx.pooler.supabase.com
DATABASE_URL=
# SUPABASE_POOLER_HOST=aws-1-ap-southeast-1.pooler.supabase.com

# --- AI Chat ---
# Local dev: n8n + Ollama (npm run ai:start) + Groq fallback ถ้ามี NUXT_AI_API_KEY
NUXT_AI_MODE=n8n
NUXT_N8N_INTERNAL_URL=http://127.0.0.1:5678
NUXT_PUBLIC_N8N_CHAT_WEBHOOK_ID=1f5ea30f-2ff0-4d32-b211-eccb342ee0df

# Vercel (แนะนำ): Groq โดยตรง — ไม่ต้องเปิด n8n บน PC
# NUXT_AI_MODE=cloud
NUXT_AI_API_KEY=gsk_xxx
NUXT_AI_PROVIDER=groq
NUXT_AI_MODEL=llama-3.3-70b-versatile

# Vercel ทางเลือก: n8n ผ่าน ngrok (NUXT_AI_MODE=n8n)
# NUXT_N8N_INTERNAL_URL=https://xxxx.ngrok-free.dev

# --- ngrok demo (optional) ---
# ngrok http 3001  →  /api/bff + /api/ai-chat + /n8n proxy อัตโนมัติ

# --- วิดีโอคอล ---
#
# วิธี A (แนะนำ): Agora.io — 10,000 นาทีฟรี/เดือน, ไม่ต้องตั้ง TURN
# 1. สมัคร https://console.agora.io → สร้าง Project → เปิด App Certificate
# 2. ใส่ค่าด้านล่าง แล้ว restart npm run dev
NUXT_PUBLIC_USE_AGORA_RTC=true
NUXT_PUBLIC_AGORA_APP_ID=your_agora_app_id
NUXT_AGORA_APP_CERTIFICATE=your_agora_app_certificate
#
# วิธี B: WebRTC + Metered TURN (เดิม) — ปิด Agora แล้วใช้ค่า TURN
# NUXT_PUBLIC_USE_AGORA_RTC=false
# สมัครฟรี https://www.metered.ca → Dashboard → TURN Server → API Key
# NUXT_METERED_API_KEY=your_metered_api_key
# NUXT_METERED_APP_NAME=telebotpharmacy
#
# วิธี C: ใส่ username/password จาก Metered dashboard โดยตรง
# NUXT_PUBLIC_TURN_URLS=turn:global.relay.metered.ca:443?transport=tcp,turns:global.relay.metered.ca:443?transport=tcp
# NUXT_PUBLIC_TURN_USERNAME=
# NUXT_PUBLIC_TURN_CREDENTIAL=
#
# วิธี D (ทดสอบเร็ว): Wi‑Fi บ้านเดียวกัน — ไม่ต้อง TURN/Agora

# --- SMTP (OTP / ลืมรหัสผ่าน) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=your@gmail.com
# SMTP_FROM_NAME=Telebot Pharmacy

# อัปโหลดรูปครั้งแรก: npm run media:seed
